{
  "servers": {
    "shadcn": {
      "command": "npx",
      "args": ["shadcn-vue@latest", "mcp"]
    },
    "ai-elements-vue": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://registry.ai-elements-vue.com/mcp"
      ]
    },
    "bullmq": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://docs.bullmq.io/~gitbook/mcp"
      ]
    }
  }
}
